# Jupiter API key — get at https://jup.ag
JUP_API_KEY=

# Solana RPC endpoint — Helius recommended: https://helius.dev
RPC_URL=https://api.mainnet-beta.solana.com

# HTTP server port (default: 4000)
# PORT=4000

# Zerion API key — set via CLI: zerion config set apiKey zk_...
# Or set here as an env var
# ZERION_API_KEY=zk_...
